@{
    ViewData["Title"] = "Dashboard";
}

<div class="container">

    <h2 class="mb-4">Dashboard</h2>

    <div class="row">

        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h3>@ViewBag.TotalCustomers</h3>
                    <p>Clientes</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <h3>@ViewBag.TotalVehicles</h3>
                    <p>Veículos</p>
                </div>
            </div>
        </div>

    </div>

</div>
