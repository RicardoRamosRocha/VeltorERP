@model IEnumerable<VeltorERP.Domain.Entities.ServiceOrder>

@{
    ViewData["Title"] = "Ordens de Serviço";
}

<h2>Ordens de Serviço</h2>

<form method="get" class="row mb-3">

    <div class="col-md-10">
        <input type="text"
               name="search"
               value="@ViewBag.Search"
               class="form-control"
               placeholder="Pesquisar por cliente, placa ou status..." />
    </div>

    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">
            Pesquisar
        </button>
    </div>

</form>

<a asp-action="Create" class="btn btn-primary mb-3">
    Nova Ordem de Serviço
</a>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Data</th>
            <th>Cliente</th>
            <th>Veículo</th>
            <th>Status</th>
            <th>Total</th>
            <th width="180"></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.OpeningDate.ToString("dd/MM/yyyy")</td>
                <td>@item.Customer?.Name</td>
                <td>@item.Vehicle?.Plate</td>
                <td>

                    @if (item.Status == "Em Aberto")
                    {
                        <span class="badge bg-warning text-dark">
                            Em Aberto
                        </span>
                    }
                    else if (item.Status == "Em Andamento")
                    {
                        <span class="badge bg-primary">
                            Em Andamento
                        </span>
                    }
                    else if (item.Status == "Aguardando Aprovação")
                    {
                        <span class="badge bg-info text-dark">
                            Aguardando Aprovação
                        </span>
                    }
                    else if (item.Status == "Finalizada")
                    {
                        <span class="badge bg-success">
                            Finalizada
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Cancelada
                        </span>
                    }

                </td>
                <td>@item.TotalAmount.ToString("C")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Excluir</a>
                    <a asp-action="Print" asp-route-id="@item.Id" class="btn btn-info btn-sm">Imprimir</a>
                </td>
            </tr>
        }
    </tbody>
</table>