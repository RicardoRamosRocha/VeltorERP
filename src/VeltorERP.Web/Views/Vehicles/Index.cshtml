@model IEnumerable<VeltorERP.Domain.Entities.Vehicle>

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold">Veículos</h2>
        <p class="text-muted">
            Gerenciamento de veículos da oficina
        </p>
    </div>

    <a asp-action="Create"
       class="btn btn-primary">
        Novo Veículo
    </a>

</div>

<table class="table table-hover">

    <thead>
        <tr>
            <th>Placa</th>
            <th>Marca</th>
            <th>Modelo</th>
            <th>Cliente</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Plate</td>
            <td>@item.Brand</td>
            <td>@item.Model</td>
            <td>@item.Customer?.Name</td>

            <td>

                <a asp-action="Edit"
                   asp-route-id="@item.Id"
                   class="btn btn-warning btn-sm">
                    Editar
                </a>

                <a asp-action="Delete"
                   asp-route-id="@item.Id"
                   class="btn btn-danger btn-sm">
                    Excluir
                </a>

            </td>

        </tr>
    }

    </tbody>

</table>