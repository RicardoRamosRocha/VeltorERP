@model IEnumerable<VeltorERP.Domain.Entities.Customer>

@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold">Clientes</h2>
        <p class="text-muted">
            Gerenciamento de clientes da oficina
        </p>
    </div>

    <a asp-action="Create"
       class="btn btn-primary">
        Novo Cliente
    </a>

</div>

<table class="table table-hover">

    <thead>

        <tr>
            <th>Nome</th>
            <th>Telefone</th>
            <th>Email</th>
            <th width="180"></th>
        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Name</td>

                <td>@item.Phone</td>

                <td>@item.Email</td>

                <td>
                    Editar |
                    Excluir
                </td>

            </tr>
        }

    </tbody>

</table>