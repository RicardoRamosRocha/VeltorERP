@model VeltorERP.Domain.Entities.Vehicle

<h2>Excluir Veículo</h2>

<p>Deseja excluir o veículo abaixo?</p>

<strong>
    @Model.Plate - @Model.Model
</strong>

<form asp-action="Delete">

    <input asp-for="Id" type="hidden" />

    <button type="submit"
            class="btn btn-danger">
        Excluir
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Cancelar
    </a>

</form>