@model VeltorERP.Domain.Entities.Vehicle

<h2>Novo Veículo</h2>

<form asp-action="Create">

    <div class="mb-3">
        <label>Cliente</label>
        <select asp-for="CustomerId"
        asp-items="ViewBag.Customers"
        class="form-select">
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Plate"></label>
        <input asp-for="Plate" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Brand"></label>
        <input asp-for="Brand" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Model"></label>
        <input asp-for="Model" class="form-control" />
    </div>

    <button type="submit"
            class="btn btn-success">
        Salvar
    </button>

</form>

@section Scripts {
    <script>
        document.getElementById("CustomerId").addEventListener("change", function () {
            const customerId = this.value;
            const vehicleSelect = document.getElementById("VehicleId");

            vehicleSelect.innerHTML = '<option value="">Carregando...</option>';

            fetch(`/ServiceOrders/GetVehiclesByCustomer?customerId=${customerId}`)
                .then(response => response.json())
                .then(data => {
                    vehicleSelect.innerHTML = '<option value="">Selecione o veículo</option>';

                    data.forEach(vehicle => {
                        const option = document.createElement("option");
                        option.value = vehicle.id;
                        option.text = vehicle.text;
                        vehicleSelect.appendChild(option);
                    });
                });
        });
    </script>
}